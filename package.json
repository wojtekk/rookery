{
  "name": "rookery",
  "productName": "Rookery",
  "version": "1.0.0-beta.1",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "description": "Rookery — Local git organized. An Electron dashboard for managing locally-cloned git repositories.",
  "main": "dist/src/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.renderer.json && pnpm run copy-assets",
    "copy-assets": "node -e \"const fs=require('fs');fs.mkdirSync('dist/renderer/src/renderer',{recursive:true});fs.mkdirSync('dist/assets',{recursive:true});fs.copyFileSync('src/renderer/index.html','dist/renderer/src/renderer/index.html');fs.copyFileSync('src/renderer/styles.css','dist/renderer/src/renderer/styles.css');fs.copyFileSync('src/assets/icon.png','dist/assets/icon.png');\"",
    "start": "pnpm run build && electron .",
    "test": "pnpm run build && node --test dist/tests/*.test.js",
    "dist": "electron-builder --publish=never",
    "preversion": "pnpm test",
    "postversion": "git push --follow-tags"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "40.8.5",
    "electron-builder": "^26.15.3",
    "typescript": "^5.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}
